      "@id": "ugs:initialBalance",
      "@type": "schema:Number"
    },
    "max": {
      "@id": "ugs:maxBalance",
      "@type": "schema:Number"
    },

    "InventoryItem": {
      "@id": "ugs:InventoryItem",
      "@type": "@id"
    },
    "instanceId": {
      "@id": "ugs:instanceId"
    },
    "inventoryItemId": {
      "@id": "ugs:inventoryItemId"
    },

    "RelayAllocation": {
