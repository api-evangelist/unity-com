    },
    "projectId": {
      "@id": "ugs:projectId"
    },
    "environmentId": {
      "@id": "ugs:environmentId"
    },
    "Environment": {
      "@id": "ugs:Environment",
      "@type": "@id"
    },

    "PlayerToken": {
